# MongoDB (opcional - actualmente se usa SQLite)
MONGO_URL=mongodb+srv://usuario:password@cluster.mongodb.net/?retryWrites=true&w=majority
DB_NAME=tecnicos_ya

# JWT Secret - ¡CAMBIAR EN PRODUCCIÓN!
SECRET_KEY=change-this-to-a-random-secret-key

# Stripe (opcional - modo demo por defecto)
STRIPE_API_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Backend URL (para enlaces de verificación)
BACKEND_URL=http://localhost:8000

# Base de datos (SQLite por defecto, usar PostgreSQL en producción)
DATABASE_URL=sqlite:///./tecnicos_ya.db

# Rate limiting (0=habilitado, 1=deshabilitado)
DISABLE_RATE_LIMITS=0

# CORS (separado por comas, * para todos)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Sembrar usuarios de prueba (1=habilitado, 0=deshabilitado)
SEED_TEST_USERS=0
