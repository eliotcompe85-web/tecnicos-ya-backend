# .env.example

# ==========================================
# Backend Configuration
# ==========================================

# Base de Datos
DATABASE_URL=sqlite:///./tecnicos_ya.db

# JWT - IMPORTANTE: Cambiar en producción
JWT_SECRET=tu-clave-secreta-super-segura-aqui-cambiar-en-produccion
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Stripe API (opcional, usar modo DEMO sin configurar)
STRIPE_API_KEY=sk_test_xxxxx

# Server
DEBUG=false
HOST=0.0.0.0
PORT=8000
WORKERS=4

# ==========================================
# Frontend Configuration
# ==========================================

# API Backend URL
EXPO_PUBLIC_API_URL=http://localhost:8000/api

# Stripe Public Key (opcional)
EXPO_PUBLIC_STRIPE_KEY=pk_test_xxxxx

# Google Maps API (opcional para Expo Maps)
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=xxxxx

# ==========================================
# Notas Importantes
# ==========================================

# 1. Para desarrollo local, los valores por defecto funcionan
# 2. Para producción, cambiar todos los valores marcados como "xxxxx"
# 3. Nunca commitear .env a git (agregar a .gitignore)
# 4. Copiar este archivo a .env y llenar valores reales
# 5. JWT_SECRET debe ser largo y aleatorio en producción

# ==========================================
# Comandos Útiles
# ==========================================

# Backend - Iniciar servidor
# uvicorn server:app --reload --host 0.0.0.0 --port 8000

# Frontend - Iniciar desarrollo
# npm start

# Tests backend
# pytest tests/test_api.py -v

# Build frontend para producción
# expo build:android
# expo build:ios
